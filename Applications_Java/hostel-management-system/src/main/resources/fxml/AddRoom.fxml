<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="250.0" prefWidth="350.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.AddRoomController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="222.0" prefWidth="322.0" spacing="15.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="30.0" prefWidth="200.0" spacing="10.0">
               <children>
      
                  <Label styleClass="app-title" text="Add Room" />
               </children>
            </HBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Room Number" />
                  <TextField fx:id="roomNumberField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Capacity" />
                  <TextField fx:id="capacityField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <Button onAction="#addRoom" prefWidth="250.0" styleClass="accent-btn" text="Add" />
         </children>
      </VBox>
   </children>
</AnchorPane>