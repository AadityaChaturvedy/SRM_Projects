<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.DashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" styleClass="app-header" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="app-title" text="Smart Hostel" />
            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="logoutButton" onAction="#logout" styleClass="logout-btn" text="Logout">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets right="20.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets left="20.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <VBox alignment="TOP_CENTER" spacing="10.0">
               <styleClass>
                  <String fx:value="card" />
               </styleClass>
               <children>
                  <Label styleClass="field-label" text="Core Management" />
                  <Button onAction="#openStudentManagement" prefWidth="200.0" styleClass="button" text="Student Management" />
                  <Button onAction="#openRoomManagement" prefWidth="200.0" styleClass="button" text="Room Management" />
                  <Button onAction="#openAttendanceManagement" prefWidth="200.0" styleClass="button" text="Attendance Management" />
                  <Button onAction="#openPaymentManagement" prefWidth="200.0" styleClass="button" text="Payment Management" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <VBox alignment="TOP_CENTER" spacing="10.0">
               <styleClass>
                  <String fx:value="card" />
               </styleClass>
               <children>
                  <Label styleClass="field-label" text="Operations" />
                  <Button onAction="#openCheckInOut" prefWidth="200.0" styleClass="button" text="Check-in / Check-out" />
                  <Button onAction="#openInventoryManagement" prefWidth="200.0" styleClass="button" text="Inventory Management" />
                  <Button onAction="#openLeaveManagement" prefWidth="200.0" styleClass="button" text="Leave Management" />
                  <Button onAction="#openVisitorManagement" prefWidth="200.0" styleClass="button" text="Visitor Management" />
                  <Button onAction="#openMessMenu" prefWidth="200.0" styleClass="button" text="Mess Menu" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <VBox alignment="TOP_CENTER" spacing="10.0">
               <styleClass>
                  <String fx:value="card" />
               </styleClass>
               <children>
                  <Label styleClass="field-label" text="Administration &amp; Reports" />
                  <Button onAction="#openComplaintManagement" prefWidth="200.0" styleClass="button" text="Complaint Management" />
                  <Button onAction="#openMaintenanceReport" prefWidth="200.0" styleClass="button" text="Maintenance Report" />
                  <Button onAction="#openReports" prefWidth="200.0" styleClass="button" text="Reports and Analytics" />
                  <Button onAction="#openAnalyticsDashboard" prefWidth="200.0" styleClass="button" text="Analytics Dashboard" />
                  <Button onAction="#openExportData" prefWidth="200.0" styleClass="button" text="Export Data" />
                  <Button onAction="#openRoleManagement" prefWidth="200.0" styleClass="button" text="Role Management" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </HBox>
   </center>
</BorderPane>