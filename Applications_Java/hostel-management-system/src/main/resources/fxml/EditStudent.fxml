<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="400.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.EditStudentController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="372.0" prefWidth="372.0" spacing="15.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="30.0" prefWidth="200.0" spacing="10.0">
               <children>
      
                  <Label styleClass="app-title" text="Edit Student" />
               </children>
            </HBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Name" />
                  <TextField fx:id="nameField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Email" />
                  <TextField fx:id="emailField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Phone" />
                  <TextField fx:id="phoneField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Address" />
                  <TextField fx:id="addressField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
               <children>
                  <Label styleClass="field-label" text="Room ID" />
                  <TextField fx:id="roomIdField" prefWidth="250.0" styleClass="text-field" />
               </children>
            </VBox>
            <Button onAction="#editStudent" prefWidth="250.0" styleClass="accent-btn" text="Save" />
         </children>
      </VBox>
   </children>
</AnchorPane>