<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="250.0" prefWidth="350.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.ExportDataController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="222.0" prefWidth="322.0" spacing="15.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="30.0" prefWidth="200.0" spacing="10.0">
               <children>
      
                  <Label styleClass="app-title" text="Export Data" />
               </children>
            </HBox>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
               <children>
                  <Label styleClass="field-label" text="Select data to export:" />
                  <Button fx:id="exportStudentsButton" onAction="#exportStudents" prefWidth="200.0" styleClass="button" text="Export Students (XLSX)" />
                  <Button onAction="#exportRooms" prefWidth="200.0" styleClass="button" text="Export Rooms (XLSX)" />
                  <Button onAction="#exportStudentsCSV" prefWidth="200.0" styleClass="button" text="Export Students (CSV)" />
                  <Button onAction="#exportRoomsCSV" prefWidth="200.0" styleClass="button" text="Export Rooms (CSV)" />
                  <Button onAction="#exportAttendanceCSV" prefWidth="200.0" styleClass="button" text="Export Attendance (CSV)" />
                  <Button onAction="#exportPaymentsCSV" prefWidth="200.0" styleClass="button" text="Export Payments (CSV)" />
                  <Button onAction="#exportComplaintsCSV" prefWidth="200.0" styleClass="button" text="Export Complaints (CSV)" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>