<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.LeaveManagementController" stylesheets="@/css/style.css">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header">
            <children>
    
                <Label text="Leave Management" styleClass="app-title" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="card">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <TableView fx:id="leaveRequestsTable" prefHeight="400.0" prefWidth="760.0">
                <columns>
                    <TableColumn fx:id="studentNameColumn" prefWidth="150.0" text="Student Name" />
                    <TableColumn fx:id="startDateColumn" prefWidth="100.0" text="Start Date" />
                    <TableColumn fx:id="endDateColumn" prefWidth="100.0" text="End Date" />
                    <TableColumn fx:id="reasonColumn" prefWidth="250.0" text="Reason" />
                    <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                    <TableColumn fx:id="requestDateColumn" prefWidth="120.0" text="Request Date" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleApprove" styleClass="button" text="Approve" />
                <Button onAction="#handleReject" styleClass="logout-btn" text="Reject" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
