<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.LoginController">
   <children>
      <VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" styleClass="login-background" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" maxWidth="400.0" prefHeight="400.0" prefWidth="300.0" spacing="20.0" styleClass="login-card">
               <children>
                  <Label styleClass="app-title" text="Smart Hostel" />
                  <Label styleClass="field-label" text="Login to your account" />
                  <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
                     <children>
                        <Label styleClass="field-label" text="Username" />
                        <TextField fx:id="usernameField" prefWidth="250.0" styleClass="text-field" promptText="Enter your username" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5.0" styleClass="form-panel">
                     <children>
                        <Label styleClass="field-label" text="Password" />
                        <PasswordField fx:id="passwordField" prefWidth="250.0" styleClass="password-field" promptText="Enter your password" />
                     </children>
                  </VBox>
                  <Button fx:id="loginButton" onAction="#login" prefWidth="250.0" styleClass="button" text="Login" />
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>