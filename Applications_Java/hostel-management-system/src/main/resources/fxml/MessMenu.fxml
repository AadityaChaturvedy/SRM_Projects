<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.MessMenuController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label styleClass="app-title" text="Mess Menu Management" />

                <TableView fx:id="menuTable" onMouseClicked="#handleRowSelect" prefHeight="300.0">
                    <columns>
                        <TableColumn fx:id="dayCol" prefWidth="120.0" text="Day" />
                        <TableColumn fx:id="breakfastCol" prefWidth="180.0" text="Breakfast" />
                        <TableColumn fx:id="lunchCol" prefWidth="180.0" text="Lunch" />
                        <TableColumn fx:id="snacksCol" prefWidth="180.0" text="Snacks" />
                        <TableColumn fx:id="dinnerCol" prefWidth="180.0" text="Dinner" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <GridPane styleClass="form-panel" hgap="10" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label styleClass="field-label" text="Day:" GridPane.rowIndex="0" />
                        <ComboBox fx:id="dayOfWeekComboBox" styleClass="text-field" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label styleClass="field-label" text="Breakfast:" GridPane.rowIndex="1" />
                        <TextField fx:id="breakfastField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="field-label" text="Lunch:" GridPane.rowIndex="2" />
                        <TextField fx:id="lunchField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label styleClass="field-label" text="Snacks:" GridPane.rowIndex="3" />
                        <TextField fx:id="snacksField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label styleClass="field-label" text="Dinner:" GridPane.rowIndex="4" />
                        <TextField fx:id="dinnerField" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button onAction="#handleAddMenu" styleClass="button" text="Add Menu" />
                        <Button onAction="#handleUpdateMenu" styleClass="button" text="Update Menu" />
                        <Button onAction="#handleDeleteMenu" styleClass="logout-btn" text="Delete Menu" />
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
