<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.OnlinePaymentController" stylesheets="@/css/style.css">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header">
            <children>
                <Label text="Online Fee Payment" styleClass="app-title" />
                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
                    <Button onAction="#closeWindow" styleClass="logout-btn" text="Close" />
                </HBox>
            </children>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="400">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label styleClass="field-label" text="Payment Amount (USD)" />
            <TextField fx:id="amountField" promptText="e.g., 500.00" />

            <Label styleClass="field-label" text="Card Number (Test)" />
            <TextField fx:id="cardNumberField" promptText="4242 4242 4242 4242" />

            <Label styleClass="field-label" text="Expiration (MM/YY)" />
            <TextField fx:id="expDateField" promptText="12/25" />

            <Label styleClass="field-label" text="CVC (Test)" />
            <TextField fx:id="cvcField" promptText="123" />

            <Button onAction="#handlePayment" styleClass="button" text="Pay Now" prefWidth="200.0"/>
            <Label fx:id="statusLabel" styleClass="muted-label" text="" />
        </VBox>
    </center>
</BorderPane>
