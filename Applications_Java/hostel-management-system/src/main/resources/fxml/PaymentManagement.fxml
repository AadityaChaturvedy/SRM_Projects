<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.PaymentManagementController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="572.0" prefWidth="772.0" spacing="20.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="200.0" spacing="10.0">
               <children>
      
                  <Label styleClass="app-title" text="Payment Management" />
               </children>
            </HBox>
            <TableView fx:id="paymentTable" prefHeight="400.0" prefWidth="700.0" styleClass="table-view">
               <columns>
                  <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                  <TableColumn fx:id="studentIdColumn" prefWidth="150.0" text="Student ID" />
                  <TableColumn fx:id="amountColumn" prefWidth="150.0" text="Amount" />
                  <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
                  <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
               </columns>
            </TableView>
            <HBox alignment="CENTER" prefHeight="30.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button onAction="#addPayment" styleClass="button" text="Add Payment" />
                  <Button onAction="#editPayment" styleClass="button" text="Edit Payment" />
                  <Button onAction="#deletePayment" styleClass="logout-btn" text="Delete Payment" />

               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>