<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.RoleManagementController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="572.0" prefWidth="772.0" spacing="20.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="200.0" spacing="10.0">
               <children>
      
                  <Label styleClass="app-title" text="Role Management" />
               </children>
            </HBox>
            <TableView fx:id="userTable" prefHeight="400.0" prefWidth="700.0" styleClass="table-view">
               <columns>
                  <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                  <TableColumn fx:id="usernameColumn" prefWidth="150.0" text="Username" />
                  <TableColumn fx:id="roleColumn" prefWidth="150.0" text="Role" />
                  <TableColumn fx:id="permissionsColumn" prefWidth="350.0" text="Permissions" />
               </columns>
            </TableView>
            <HBox alignment="CENTER" prefHeight="30.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button onAction="#editUserRoles" styleClass="button" text="Edit User Roles" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>