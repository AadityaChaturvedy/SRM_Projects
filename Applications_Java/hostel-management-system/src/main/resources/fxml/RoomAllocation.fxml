<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.RoomAllocationController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="572.0" prefWidth="772.0" spacing="20.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="200.0" spacing="10.0">
               <children>
      
                  <Label styleClass="app-title" text="Room Allocation" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
               <children>
                  <VBox alignment="CENTER_LEFT" spacing="5.0" styleClass="form-panel">
                     <children>
                        <Label styleClass="field-label" text="Student ID" />
                        <TextField fx:id="studentIdField" styleClass="text-field" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" spacing="5.0" styleClass="form-panel">
                     <children>
                        <Label styleClass="field-label" text="Room ID" />
                        <TextField fx:id="roomIdField" styleClass="text-field" />
                     </children>
                  </VBox>
                  <Button onAction="#allocateRoom" styleClass="accent-btn" text="Allocate Room" />
                  <Button onAction="#deallocateRoom" styleClass="logout-btn" text="Deallocate Room" />
               </children>
            </HBox>
            <TableView fx:id="studentTable" prefHeight="200.0" prefWidth="200.0" styleClass="table-view">
               <columns>
                  <TableColumn fx:id="studentIdColumn" prefWidth="75.0" text="Student ID" />
                  <TableColumn fx:id="studentNameColumn" prefWidth="150.0" text="Student Name" />
                  <TableColumn fx:id="allocatedRoomIdColumn" prefWidth="75.0" text="Allocated Room ID" />
               </columns>
            </TableView>
            <TableView fx:id="roomTable" prefHeight="200.0" prefWidth="200.0" styleClass="table-view">
               <columns>
                  <TableColumn fx:id="roomIdColumnTable" prefWidth="75.0" text="Room ID" />
                  <TableColumn fx:id="roomNumberColumn" prefWidth="100.0" text="Room Number" />
                  <TableColumn fx:id="roomCapacityColumn" prefWidth="75.0" text="Capacity" />
                  <TableColumn fx:id="roomStatusColumn" prefWidth="100.0" text="Status" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>