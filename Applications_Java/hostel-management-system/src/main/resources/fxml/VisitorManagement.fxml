<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hostel.controllers.VisitorManagementController" stylesheets="@/css/style.css">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header">
            <children>
    
                <Label text="Visitor Management" styleClass="app-title" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="card">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <TableView fx:id="visitorTable" prefHeight="400.0" prefWidth="760.0">
                <columns>
                    <TableColumn fx:id="studentNameColumn" prefWidth="150.0" text="Student Name" />
                    <TableColumn fx:id="visitorNameColumn" prefWidth="150.0" text="Visitor Name" />
                    <TableColumn fx:id="relationColumn" prefWidth="100.0" text="Relation" />
                    <TableColumn fx:id="visitDateColumn" prefWidth="120.0" text="Visit Date" />
                    <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleAllowEntry" styleClass="button" text="Allow Entry" />
                <Button onAction="#handleDenyEntry" styleClass="logout-btn" text="Deny Entry" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
